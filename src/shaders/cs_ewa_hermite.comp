#extension GL_GOOGLE_include_directive : require
#extension GL_EXT_scalar_block_layout   : require

// EWA Hermite downscaler.
//
// Kernel (Hermite / "cubic Hermite" reconstruction filter):
//
//     h(x) = (2|x| - 3) * x^2 + 1   for |x| <= 1
//     h(x) = 0                      otherwise
//
// Equivalent to the Mitchell-Netravali filter at B = C = 0 and to
// libplacebo's pl_filter_hermite (see libplacebo/src/filters.c). The
// kernel has no negative lobes, so no ringing can appear and no
// anti-ringing clamp is required — this makes Hermite a fast, safe
// downscaler that's well-suited to supersampled input that's already
// been rendered above the output resolution.
//
// For downscaling by a factor F >= 1 (input/output) the filter support
// is stretched by F so the output integrates ~F^2 input samples; for
// upscaling (F < 1) the filter runs at its native support. This is
// the same scheme libplacebo uses for polar filters.

#include "descriptor_set.h"

layout( local_size_x = 8, local_size_y = 8, local_size_z = 1 ) in;

layout( binding = 0, scalar )
uniform hermite_push_t {
    vec2  u_invInputSize;   // 1.0 / input_size
    vec2  u_invOutputSize;  // 1.0 / output_size
    vec2  u_inputSize;      // textureSize of layer 0
    vec2  u_scale;          // input_size / output_size (>1 means downscale)
};

const float HERMITE_RADIUS = 1.0;

// Evaluate the Hermite kernel at unit-space distance `x`
// (i.e. the kernel already scaled by 1/F for the downscale factor).
float hermite_weight( float x )
{
    if ( x >= HERMITE_RADIUS )
        return 0.0;
    // (2x - 3) * x^2 + 1, monotonically decreasing from 1 at x=0 to 0 at x=1.
    return ( 2.0 * x - 3.0 ) * x * x + 1.0;
}

// Inline sRGB transfer functions.
//
// The input texture is bound with setTextureSrgb(true), which on this
// codebase selects the UNORM image view — no hardware sRGB decode. So
// we receive raw sRGB-encoded bytes and must linearise them ourselves
// before averaging, otherwise the kernel sum is performed in
// gamma-encoded space, which darkens mixed regions unevenly across
// colour channels (observed in-game as a warm/orange cast on blended
// edges). We re-encode the averaged result before imageStore so the
// downstream composite shader still sees sRGB-encoded values in the
// intermediate texture, matching the FSR / NIS pipeline contract.
//
// These helpers are inlined instead of pulled in from colorimetry.h
// because that header references composite-shader push-constant
// uniforms (u_nitsToLinear, u_scale[], ...) that this shader does
// not have.
vec3 _ewa_srgb_to_linear( vec3 c )
{
    bvec3 isLo = lessThanEqual( c, vec3( 0.04045 ) );
    vec3 loPart = c / 12.92;
    vec3 hiPart = pow( ( c + 0.055 ) / 1.055, vec3( 2.4 ) );
    return mix( hiPart, loPart, isLo );
}

vec3 _ewa_linear_to_srgb( vec3 c )
{
    bvec3 isLo = lessThanEqual( c, vec3( 0.0031308 ) );
    vec3 loPart = c * 12.92;
    vec3 hiPart = pow( max( c, vec3( 0.0 ) ), vec3( 1.0 / 2.4 ) ) * 1.055 - 0.055;
    return mix( hiPart, loPart, isLo );
}

// Linearise a fetched sample based on the layer-0 colorspace spec
// constant. Only sRGB is transformed explicitly; other colorspaces
// (linear / scRGB / PQ / passthru) are left untouched because correctly
// handling them requires the full composite uniform block.
vec3 _ewa_degamma( vec3 c )
{
    uint cs = get_layer_colorspace( 0 );
    if ( cs == colorspace_sRGB )
        return _ewa_srgb_to_linear( c );
    return c;
}

vec3 _ewa_regamma( vec3 c )
{
    uint cs = get_layer_colorspace( 0 );
    if ( cs == colorspace_sRGB )
        return _ewa_linear_to_srgb( c );
    return c;
}

void main()
{
    ivec2 outPos = ivec2( gl_GlobalInvocationID.xy );
    ivec2 outExt = imageSize( dst );
    if ( outPos.x >= outExt.x || outPos.y >= outExt.y )
        return;

    // Center of the output pixel in normalized output coordinates -> input coords.
    vec2 inCenter = ( vec2( outPos ) + vec2( 0.5 ) ) * u_scale;

    // Downscale factor per axis (>=1 for downscaling, clamped for upscaling).
    vec2 F = max( u_scale, vec2( 1.0 ) );
    // Use the largest factor to form a circular support in input space.
    float Fmax = max( F.x, F.y );

    // Integer search window in input pixels (symmetric around center).
    int bound = int( ceil( HERMITE_RADIUS * Fmax ) ) + 1;
    // Safety cap. Hermite's native radius is 1, so `bound` grows linearly
    // with the downscale factor; 10 covers factors up to ~9x which is well
    // beyond anything the rest of the pipeline currently supports.
    if ( bound > 10 ) bound = 10;

    ivec2 baseTexel = ivec2( floor( inCenter - vec2( 0.5 ) ) );

    vec4  color   = vec4( 0.0 );
    float wsum    = 0.0;

    for ( int dy = -bound; dy <= bound; ++dy )
    {
        for ( int dx = -bound; dx <= bound; ++dx )
        {
            ivec2 p = baseTexel + ivec2( dx, dy );
            vec2  sc = vec2( p ) + vec2( 0.5 );
            float d  = length( sc - inCenter );
            if ( d >= HERMITE_RADIUS * Fmax )
                continue;

            float xUnit = d / Fmax;
            float w     = hermite_weight( xUnit );
            if ( w <= 0.0 )
                continue;

            vec2 uv = sc * u_invInputSize;
            vec4 s  = textureLod( s_samplers[0], uv, 0.0 );
            s.rgb   = _ewa_degamma( s.rgb );

            color += s * w;
            wsum  += w;
        }
    }

    if ( wsum > 0.0 )
        color /= wsum;

    // Hermite has no negative lobes so no anti-ringing clamp is needed.

    color.rgb = _ewa_regamma( color.rgb );
    imageStore( dst, outPos, color );
}
